; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="风尘叹"
config/description="Wuxia open-world RPG. Whispers of the Wanderer."
config/version="0.1.0"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.6")
config/icon="res://assets/ui/icon.svg"

[autoload]

GameManager="*res://scripts/core/game_manager.gd"
DataManager="*res://scripts/core/data_manager.gd"
EventBus="*res://scripts/core/event_bus.gd"
SaveManager="*res://scripts/core/save_manager.gd"
NotificationManager="*res://scripts/core/notification_manager.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor]

main_run_args=""

