    {
      "id": "main_ch1_03",
      "name": "玉佩之谜",
      "type": "main",
      "chapter": 1,
      "levelRequired": 5,
      "prerequisites": { "quests": ["main_ch1_02"] },
      "description": "从山贼手中救出的一名老者认出了你的玉佩，他说这玉佩与二十年前的一桩旧事有关，建议你去少林寺藏经阁查阅典籍。",
      "giverNpc": "old_man_rescued",
      "giverLocation": "luoyang_inn",
      "objectives": [
        { "type": "talk", "description": "与获救的老者交谈", "targetId": "old_man_rescued", "location": "luoyang_inn" },
        { "type": "explore", "description": "前往少林寺", "targetId": "shaolin_temple", "location": "songshan" },
        { "type": "talk", "description": "请求藏经阁长老允许查阅典籍", "targetId": "librarian_monk", "location": "shaolin_library" }
      ],
      "choices": [
        {
          "nodeId": "choice_shaolin_entry",
          "description": "如何进入藏经阁？",
          "options": [
            { "text": "以礼相求，说明来意（需侠义值≥50）", "consequences": { "affinity": { "librarian_monk": 10 } } },
            { "text": "捐赠香火钱（消耗500铜钱）", "consequences": { "copper": -500 } },
            { "text": "夜深人静时潜入（需身法≥15）", "consequences": { "reputation": { "xiayi": -10 }, "riskOfCaught": 0.3 } }
          ]
        }
      ],
      "rewards": {
        "experience": 500,
        "silver": 1,
        "reputation": { "jianghu": 50 }
      },
      "estimatedDuration": 30
    }
  ],

