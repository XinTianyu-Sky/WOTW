      "name": "山贼之患",
      "type": "main",
      "chapter": 1,
      "levelRequired": 2,
      "prerequisites": { "quests": ["main_ch1_01"] },
      "description": "洛阳城外的山贼日益猖獗，洛阳捕头正在招募江湖侠士前往剿灭。这是你扬名立万的好机会。",
      "giverNpc": "captain_zhang",
      "giverLocation": "luoyang_yamen",
      "objectives": [
        { "type": "talk", "description": "前往洛阳衙门与张捕头交谈", "targetId": "captain_zhang", "location": "luoyang_yamen" },
        { "type": "explore", "description": "前往城外的山贼营地", "targetId": "bandit_camp", "location": "luoyang_outskirts" },
        { "type": "kill", "description": "击败山贼头目", "targetId": "bandit_chief", "count": 1 },
        { "type": "collect", "description": "收集被劫的官银", "targetId": "stolen_silver", "count": 3 }
      ],
      "rewards": {
        "experience": 300,
        "copper": 500,
        "items": ["iron_sword"],
        "reputation": { "jianghu": 30, "zhongyuan": 20, "xiayi": 15 }
      },
      "estimatedDuration": 25
