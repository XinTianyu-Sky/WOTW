  "dialogues": [
    {
      "id": "dlg_old_beggar_first",
      "name": "老乞丐初次对话",
      "relatedNpc": "old_beggar",
      "startNode": "node_01",
      "nodes": {
        "node_01": {
          "id": "node_01",
          "speaker": "old_beggar",
          "expression": "squint",
          "text": "这位少侠，一看就是初来乍到吧？老叫花子在洛阳待了三十年，这城里的事，没有我不知道的。",
          "choices": [
            { "id": "c1", "text": "（恭敬行礼）老前辈，晚辈初到洛阳，想打听一些消息。", "effects": { "affinityChange": 5 }, "nextNode": "node_02a" },
            { "id": "c2", "text": "（扔下几枚铜钱）说吧，你知道些什么？", "effects": { "affinityChange": -3 }, "nextNode": "node_02b" },
            { "id": "c3", "text": "一个乞丐能知道什么？别浪费我时间。", "effects": { "affinityChange": -20 }, "nextNode": "node_02c" }
          ]
        },
        "node_02a": {
          "id": "node_02a",
          "speaker": "old_beggar",
          "expression": "pleased",
          "text": "哈哈哈，难得有人对老叫花子这么客气。你想打听什么？江湖大事，还是洛阳城的犄角旮旯？",
          "nextNode": "node_03"
        },
        "node_02b": {
          "id": "node_02b",
          "speaker": "old_beggar",
          "expression": "neutral",
          "text": "铜钱虽少，也是一番心意。老叫花子就告诉你吧——最近城外山贼闹得厉害，官府正在招募人手。",
          "effects": { "startQuest": "main_ch1_02" },
          "nextNode": "node_end"
        },
        "node_02c": {
          "id": "node_02c",
          "speaker": "old_beggar",
          "expression": "angry",
          "text": "哼，狗眼看人低！老叫花子虽然衣衫褴褛，却也曾是江湖上响当当的人物。你这种人，不配听我说话！",
          "nextNode": "node_end"
        },
        "node_03": {
          "id": "node_03",
          "speaker": "old_beggar",
          "expression": "serious",
          "text": "说到大事……少侠，你腰间那块玉佩，可否让老叫花子看看？",
          "choices": [
            { "id": "c4", "text": "（递过玉佩）前辈认得此物？", "nextNode": "node_04" },
            { "id": "c5", "text": "（警惕地收回玉佩）这是我的私人物品。", "effects": { "affinityChange": -10 }, "nextNode": "node_end" }
          ]
        },
        "node_04": {
          "id": "node_04",
          "speaker": "old_beggar",
          "expression": "shocked",
          "text": "这……这是「七星佩」！没想到老叫花子有生之年还能再见到它。少侠，你这玉佩从何而来？",
          "effects": { "setFlag": "jade_identified" },
          "nextNode": "node_end"
        },
        "node_end": {
          "id": "node_end",
          "speaker": "system",
          "text": "（对话结束）"
        }
      }
    }
  ]
}