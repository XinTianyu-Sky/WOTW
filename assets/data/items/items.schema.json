{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wotw.game/schemas/items.schema.json",
  "title": "WOTW Items & Equipment Schema",
  "description": "物品与装备数据模型",

  "definitions": {
    "itemRarity": {
      "type": "string",
      "enum": ["common", "uncommon", "rare", "epic", "legendary", "mythic"],
      "description": "凡品/良品/上品/极品/神兵/传说"
    },
    "equipmentSlot": {
      "type": "string",
      "enum": ["weapon", "offhand", "head", "body", "feet", "accessory1", "accessory2"],
      "description": "装备槽位"
    },
    "weaponType": {
      "type": "string",
      "enum": ["sword", "blade", "spear", "staff", "fist", "hidden_weapon", "zither", "fan"],
      "description": "武器类型"
    },
    "itemType": {
      "type": "string",
      "enum": ["equipment", "consumable", "material", "quest", "skill_book", "treasure", "furniture"],
      "description": "物品大类"
    }
  },

  "type": "object",
  "properties": {
    "equipment": { "type": "array", "items": { "$ref": "#/equipmentItem" } },
    "consumables": { "type": "array", "items": { "$ref": "#/consumableItem" } },
    "materials": { "type": "array", "items": { "$ref": "#/materialItem" } },
    "skillBooks": { "type": "array", "items": { "$ref": "#/skillBookItem" } }
  },

  "equipmentItem": {
    "type": "object",
    "required": ["id", "name", "slot", "rarity"],
    "properties": {
      "id": { "type": "string" },
      "name": { "type": "string" },
      "slot": { "$ref": "#/definitions/equipmentSlot" },
      "rarity": { "$ref": "#/definitions/itemRarity" },
      "weaponType": { "$ref": "#/definitions/weaponType" },
      "levelRequired": { "type": "integer", "default": 1 },
      "description": { "type": "string" },
      "baseStats": {
        "type": "object",
        "description": "基础属性",
        "properties": {
          "attack": { "type": "integer" },
          "defense": { "type": "integer" },
          "hp": { "type": "integer" },
          "qi": { "type": "integer" },
          "speed": { "type": "integer" },
          "innerPower": { "type": "integer" },
          "innerDefense": { "type": "integer" }
        }
      },
      "bonusStats": {
        "type": "object",
        "description": "百分比加成",
        "properties": {
          "critRate": { "type": "number" },
          "critDamage": { "type": "number" },
          "hitRate": { "type": "number" },
          "dodgeRate": { "type": "number" },
          "blockRate": { "type": "number" }
        }
      },
      "affixes": {
        "type": "array",
        "description": "随机词缀池",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "effect": { "type": "object", "additionalProperties": { "type": "number" } }
          }
        }
      },
      "setId": { "type": "string", "description": "所属套装ID" },
      "price": { "type": "integer", "description": "售价（铜钱）" },
      "craftable": { "type": "boolean", "default": false },
      "craftRecipe": {
        "type": "object",
        "properties": {
          "forgeLevel": { "type": "integer" },
          "materials": { "type": "object", "additionalProperties": { "type": "integer" } },
          "successRate": { "type": "number" }
        }
      }
    }
  },

  "consumableItem": {
    "type": "object",
    "required": ["id", "name", "type", "rarity"],
    "properties": {
      "id": { "type": "string" },
      "name": { "type": "string" },
      "type": {
        "type": "string",
        "enum": ["healing", "qiRestore", "buff", "cultivation", "permanent", "special"]
      },
      "rarity": { "$ref": "#/definitions/itemRarity" },
      "description": { "type": "string" },
      "effects": { "type": "object", "additionalProperties": { "type": "number" } },
      "duration": { "type": "integer", "description": "Buff持续时间（分钟），0=瞬间" },
      "cooldown": { "type": "integer", "description": "使用冷却（秒）" },
      "price": { "type": "integer" },
      "craftRecipe": {
        "type": "object",
        "properties": {
          "alchemyLevel": { "type": "integer" },
          "materials": { "type": "object", "additionalProperties": { "type": "integer" } }
        }
      }
    }
  },

  "materialItem": {
    "type": "object",
    "required": ["id", "name", "type", "rarity"],
    "properties": {
      "id": { "type": "string" },
      "name": { "type": "string" },
      "type": {
        "type": "string",
        "enum": ["ore", "herb", "wood", "cloth", "gem", "monster_part", "special"]
      },
      "rarity": { "$ref": "#/definitions/itemRarity" },
      "description": { "type": "string" },
      "sourceRegions": { "type": "array", "items": { "type": "string" } },
      "gatherSkillRequired": { "type": "integer", "default": 0 },
      "price": { "type": "integer" }
    }
  },

  "skillBookItem": {
    "type": "object",
    "required": ["id", "name", "skillId", "skillType"],
    "properties": {
      "id": { "type": "string" },
      "name": { "type": "string" },
      "skillId": { "type": "string", "description": "对应武学ID" },
      "skillType": { "type": "string", "enum": ["external", "internal", "lightness"] },
      "rarity": { "$ref": "#/definitions/itemRarity" },
      "description": { "type": "string" },
      "isFragment": { "type": "boolean", "default": false },
      "fragmentsRequired": { "type": "integer", "description": "残卷合成所需数量" },
      "price": { "type": "integer" }
    }
  }
}